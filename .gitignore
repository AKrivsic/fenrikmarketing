# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.cursor/

# --- Video worker runtime (TTS, subtitles, scene stills, render intermediates) ---
.video-worker-tmp/

# --- Local script exports (production audits, prompt experiments, markdown dumps) ---
scripts/output/

# --- Test / coverage / Playwright ---
coverage/
playwright-report/
test-results/
blob-report/
playwright/.cache/

# --- Caches & logs ---
.turbo
.cache
*.log
logs/

# --- Generated media (scoped — do not use repo-wide *.png; public/ has brand assets) ---
.video-worker-tmp/**/*
scripts/output/**/*
**/.video-worker-tmp/
**/test-results/
**/playwright-report/
