# Copy to .env.local and fill in values.
# Admin → Settings lists which integrations are configured (no secret values).

# Google Analytics 4 — optional; no tracking when unset
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Supabase (required for sample requests and app data)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Sample request notifications (Resend) — optional; leads still save if unset
RESEND_API_KEY=
CONTACT_FROM=
CONTACT_TO=

# Public landing (/content-packages) — which sample package/video to show
# Optional: pin an exact render or package; otherwise auto-picks the best eligible package.
# Test / scene-editor packages are excluded by default (see landing-sample-config.ts).
# LANDING_SAMPLE_VIDEO_JOB_ID=
# LANDING_SAMPLE_PACKAGE_ID=
# LANDING_SAMPLE_EXCLUDE_PACKAGE_IDS=

# Scene Types (Phase 2+) — when false, only IMAGE scenes render (production default).
# SCENE_TYPES_ENABLED=false
#
# CHECKLIST production rollout — comma-separated project UUIDs, or `*` for all projects.
# Empty/unset = no CHECKLIST project access. Requires SCENE_TYPES_ENABLED=true
# and CHECKLIST_GENERATION_MODE=enabled. See docs/video-production-activation.md.
# CHECKLIST_GENERATION_MODE=off|shadow|enabled
# CHECKLIST_ENABLED_PROJECT_IDS=*
